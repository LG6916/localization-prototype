__pycache__/
*.pyc
cache/
uploads/
.DS_Store
.env

# Model weights and checkpoints — ignored by default so random auto-downloads
# don't get committed. Anything *deliberately* bundled with the repo belongs
# in assets/ and is whitelisted below.
*.pt
*.onnx
*.bin
*.pkl
*.safetensors
!assets/*.pt
!assets/*.onnx
!assets/*.safetensors

# IDE cruft
.vscode/
.idea/
*.swp
